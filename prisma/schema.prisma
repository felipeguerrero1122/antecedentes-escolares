generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  nombre       String
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Alumno {
  id            String   @id @default(uuid()) @db.Uuid
  matricula     String
  apellidos     String
  nombres       String
  sexo          String?
  fechaNac      DateTime?
  run           String
  curso         String?
  direccion     String?
  comuna        String?
  procedencia   String?
  fechaIncorp   DateTime?
  cursosRep     String?
  fechaRetiro   DateTime?
  causalRetiro  String?
  fechaEgreso   DateTime?
  nivelPadre    String?
  nivelMadre    String?
  convivencia   String?
  apNombres     String?
  apDireccion   String?
  apEmail       String?
  apCelular     String?
  apEmergencia  String?
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
